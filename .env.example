# ─── Claude Feedback ─────────────────────────────────────────────────
# Master toggle. Set to "1" or "true" to enable. Omit on production.
CLAUDE_FEEDBACK_ENABLED=1

# ─── Target 1: GitHub issues ─────────────────────────────────────────
# Configured by setting both of the following. Leave both empty to
# hide this target.

# GitHub repo to file issues in. Format: "owner/name".
GITHUB_REPO=neekmode/my-app

# Fine-grained PAT scoped to the repo above with:
#   Repository permissions → Issues: Read and write
GITHUB_FEEDBACK_TOKEN=github_pat_replace_me

# Optional — defaults to "dev-feedback,claude-task"
# CLAUDE_FEEDBACK_LABELS=dev-feedback,claude-task

# Optional — if set AND @vercel/blob is installed, screenshots are
# uploaded and embedded in the issue body.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me

# ─── Target 2: Local inbox (tether) ─────────────────────────────────
# When set, the widget exposes a second target that writes feedback as
# a dated markdown file (+ optional PNG) into this directory. A live
# Claude Code session watching the directory reads it and starts work.
# Use absolute paths. Leave unset to hide this target.
#
# CLAUDE_FEEDBACK_INBOX_DIR=/Users/you/Workspace/my-app/.claude-inbox
