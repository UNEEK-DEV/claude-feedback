{
  "name": "@uneek/claude-feedback",
  "version": "0.2.0",
  "description": "Drop-in in-product feedback widget with two targets: file a @claude-tagged GitHub issue, or drop the report into a local inbox directory for a live Claude Code session to pick up. Small circle launcher, element picker, annotated screenshot, env-driven toggles.",
  "keywords": [
    "claude",
    "claude-code",
    "feedback",
    "github-issues",
    "nextjs",
    "react",
    "bug-report",
    "vercel"
  ],
  "author": "THE ARCHITECT <niko@uneek.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neekmode/claude-feedback.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./widget": {
      "types": "./src/widget.tsx",
      "default": "./src/widget.tsx"
    },
    "./action": {
      "types": "./src/submit-action.ts",
      "default": "./src/submit-action.ts"
    },
    "./inbox": {
      "types": "./src/submit-inbox-action.ts",
      "default": "./src/submit-inbox-action.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "dependencies": {
    "html-to-image": "^1.11.13"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@vercel/blob": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@vercel/blob": "^0.27.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
